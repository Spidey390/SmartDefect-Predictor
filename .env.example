# JIRA API Configuration
# Copy this file to .env and fill in your actual values

# Your JIRA instance URL (e.g., https://your-domain.atlassian.net)
JIRA_URL=https://your-domain.atlassian.net

# Your JIRA email address
JIRA_EMAIL=your-email@example.com

# Your JIRA API token (generate at https://id.atlassian.com/manage/api-tokens)
JIRA_API_TOKEN=your-api-token-here

# Default project key to analyze (optional)
DEFAULT_PROJECT_KEY=

# Maximum issues to fetch per request (optional, default: 1000)
MAX_JIRA_ISSUES=1000
