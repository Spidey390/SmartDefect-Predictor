# SmartDefect Predictor - Environment Configuration
# Copy this file to .env and fill in your actual values

# ==================== APPLICATION ====================
FLASK_ENV=development
SECRET_KEY=4372c24f7adf8e75ca1a33ccdbb373b727c6a2baa37769ceaaa19df02115d3b6
PORT=10000
DB_PATH=database.db

# ==================== JIRA API ====================
# Get your API token from: https://id.atlassian.com/manage/api-tokens
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token-here

# Default project key to analyze (optional)
DEFAULT_PROJECT_KEY=

# Maximum issues to fetch per request (optional, default: 1000)
MAX_JIRA_ISSUES=1000

# ==================== GOOGLE OAUTH ====================
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create a new project or select existing
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Client ID
# 4. Add authorized redirect URI: http://localhost:10000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==================== PRODUCTION SETTINGS ====================
# For production deployment, set:
# FLASK_ENV=production
# SECRET_KEY=<strong-random-key-50-chars>
# Add your production domain to Google OAuth authorized redirect URIs:
# https://your-domain.com/api/auth/google/callback
